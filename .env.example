# ===========================================
# PAManager - Configurazione Ambiente
# ===========================================
# Copiare questo file in .env e configurare i valori
# IMPORTANTE: Non committare mai .env in git!

# ===========================================
# APPLICAZIONE
# ===========================================
APP_URL=https://www.lemio.it/pamanager/public
DEBUG_MODE=false

# URL base (lasciare vuoto per auto-detection)
# BASE_URL=/pamanager

# ===========================================
# DATABASE
# ===========================================
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=mylemiom_calendia
DB_USERNAME=mylemiom_calendiaserver
DB_PASSWORD=your_password_here

# ===========================================
# SICUREZZA - JWT (OBBLIGATORIO IN PRODUZIONE)
# ===========================================
# Genera con: php -r "echo bin2hex(random_bytes(32));"
# ATTENZIONE: Senza questo, le API non funzioneranno in produzione!
JWT_SECRET=GENERA_UNA_STRINGA_RANDOM_DI_64_CARATTERI
JWT_EXPIRY=3600

# ===========================================
# ORGANIZZAZIONE
# ===========================================
ORG_NAME=Comune di Example
ORG_DISPLAY_NAME=Comune di Example
ORG_URL=https://www.comune.example.it
ORG_FISCAL_CODE=00000000000

# ===========================================
# CONTATTI
# ===========================================
TECH_CONTACT_NAME=Supporto Tecnico
TECH_CONTACT_EMAIL=supporto@comune.example.it

# ===========================================
# EMAIL (opzionale)
# ===========================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=password
# SMTP_FROM=noreply@example.com
# SMTP_FROM_NAME=PAManager
