# PAManager - Configurazione Apache
# SICUREZZA E REGOLE DI REWRITE

# Upload limits (override conf.d se docker layer cached)
php_value upload_max_filesize 80M
php_value post_max_size 100M
php_value memory_limit 512M
php_value max_execution_time 300
php_value max_input_time 300

# Abilita il motore di rewrite
RewriteEngine On

# Imposta la base per i rewrite (automatico dalla directory corrente)
# RewriteBase /  # Decommenta e adatta se necessario

# ====================================
# SICUREZZA
# ====================================

# Blocca accesso a file sensibili
<FilesMatch "\.(env|log|sql|bak|config|ini)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Blocca accesso a file nascosti (es. .htaccess, .gitignore)
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Previene directory listing
Options -Indexes

# Nota: Non disabilitare PHP qui, serve per le pagine

# ====================================
# HEADERS DI SICUREZZA
# ====================================

<IfModule mod_headers.c>
    # Previene MIME sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Protezione clickjacking
    Header always set X-Frame-Options "DENY"

    # Protezione XSS
    Header always set X-XSS-Protection "1; mode=block"

    # Referrer Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions Policy
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"

    # Rimuovi header server info
    Header unset X-Powered-By
    Header unset Server
</IfModule>

# ====================================
# FORCE HTTPS (Decommentare in produzione)
# ====================================
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ====================================
# COMPRESSIONE GZIP
# ====================================

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
</IfModule>

# ====================================
# CACHE STATICA
# ====================================

<IfModule mod_expires.c>
    ExpiresActive On

    # Immagini (foto profilo, asset, ecc.)
    ExpiresByType image/jpeg "access plus 6 months"
    ExpiresByType image/png "access plus 6 months"
    ExpiresByType image/gif "access plus 6 months"
    ExpiresByType image/svg+xml "access plus 6 months"
    ExpiresByType image/webp "access plus 6 months"
    ExpiresByType image/x-icon "access plus 1 year"

    # CSS e JavaScript
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"

    # Font
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
</IfModule>

# Foto profilo + asset upload: cache private + immutable per ridurre carico
<IfModule mod_headers.c>
    <FilesMatch "\.(webp|jpg|jpeg|png|gif|svg|woff2|woff|ico)$">
        Header set Cache-Control "public, max-age=15552000, immutable"
        Header unset Pragma
    </FilesMatch>
    # Service Worker: niente cache HTTP (così gli aggiornamenti arrivano subito).
    # NOTA: NON usare no-store: bloccherebbe anche il SW Cache API.
    <FilesMatch "^sw\.js$">
        Header set Cache-Control "no-cache, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
    # offline.html: must-revalidate via no-cache; il Cache API del SW deve poterla salvare.
    <FilesMatch "^offline\.html$">
        Header set Cache-Control "no-cache, must-revalidate"
        Header unset Pragma
    </FilesMatch>
</IfModule>

# Compressione anche per WebP/SVG
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ====================================
# REWRITE RULES
# ====================================

# Non applicare regole a file esistenti
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Route tutte le richieste a index.php (opzionale, per routing centralizzato)
# RewriteRule ^(.*)$ index.php [QSA,L]

# ====================================
# LIMITI UPLOAD
# ====================================

<IfModule mod_php.c>
    php_value upload_max_filesize 80M
    php_value post_max_size 100M
    php_value max_execution_time 300
    php_value max_input_time 300
</IfModule>

# ====================================
# PROTEZIONE AGGIUNTIVA
# ====================================

# Blocca alcune query string dannose
RewriteCond %{QUERY_STRING} (<|%3C).*script.*(>|%3E) [NC,OR]
RewriteCond %{QUERY_STRING} GLOBALS(=|\[|\%[0-9A-Z]{0,2}) [OR]
RewriteCond %{QUERY_STRING} _REQUEST(=|\[|\%[0-9A-Z]{0,2})
RewriteRule .* - [F,L]
