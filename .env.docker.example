# PAManager — Variabili Docker / Dokploy
# Su Dokploy queste variabili si impostano dal pannello UI (App > Environment).
# In locale: copia in `.env` per docker compose.

# === Database (interno al compose) ===
DB_NAME=pamanager
DB_USER=pamanager
DB_PASS=changeme_strong_password
DB_ROOT_PASS=changeme_root_password

# === Applicazione ===
APP_URL=https://your-domain.com
MIGRATION_TOKEN=change_me_to_random_string
JWT_SECRET=change-me-generate-32-random-chars-here
RUN_MIGRATIONS=true

# === SMTP globale (SaaS) — invio email piattaforma ===
# Unico account per tutte le aziende. Nessuna config SMTP per-azienda.
SMTP_ENABLED=1
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_ENCRYPTION=ssl
SMTP_USERNAME=your-smtp-user@example.com
SMTP_PASSWORD=your-smtp-app-password
SMTP_FROM_EMAIL=noreply@connecteed.com
SMTP_FROM_NAME=ConnecteedHR

# === Superadmin (pannello /superadmin) ===
# Genera con: php tools/superadmin-init.php
SUPERADMIN_USER=
SUPERADMIN_PASS_HASH=
SUPERADMIN_TOTP_SECRET=
